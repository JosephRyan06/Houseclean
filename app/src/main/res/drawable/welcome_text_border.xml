<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Soft Blur Shadow Layers (Concentrated at the Bottom) -->
    <item android:left="4dp" android:top="6dp" android:right="4dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <corners android:radius="8dp" />
            <solid android:color="#05000000" />
        </shape>
    </item>
    <item android:left="4dp" android:top="7dp" android:right="4dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="8dp" />
            <solid android:color="#0A000000" />
        </shape>
    </item>
    <item android:left="4dp" android:top="8dp" android:right="4dp" android:bottom="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="8dp" />
            <solid android:color="#15000000" />
        </shape>
    </item>

    <!-- Main White Background (No Stroke) -->
    <item android:bottom="6dp" android:left="4dp" android:right="4dp" android:top="4dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF" />
            <corners android:radius="8dp" />
            <padding
                android:bottom="8dp"
                android:left="14dp"
                android:right="14dp"
                android:top="8dp" />
        </shape>
    </item>
</layer-list>