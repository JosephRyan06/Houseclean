<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Glow/Shadow layers for 0 x,y position -->
    <item android:left="1dp" android:right="1dp" android:top="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="10dp" />
            <solid android:color="#20C03131" />
        </shape>
    </item>
    <item android:left="2dp" android:right="2dp" android:top="2dp" android:bottom="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="9dp" />
            <solid android:color="#40C03131" />
        </shape>
    </item>

    <!-- Main Button Body -->
    <item android:left="3dp" android:right="3dp" android:top="3dp" android:bottom="3dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:endColor="#C03131"
                android:startColor="#5A1734"
                android:type="linear" />
            <corners android:radius="8dp" />
        </shape>
    </item>
</layer-list>