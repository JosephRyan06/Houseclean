<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer Blur-like Shadow Layers (Shifted down to hide top) -->
    <item android:top="-2dp" android:bottom="1dp" android:left="1dp" android:right="1dp">
        <shape android:shape="rectangle">
            <corners android:bottomLeftRadius="10dp" android:bottomRightRadius="10dp" />
            <solid android:color="#103FBFF5" />
        </shape>
    </item>
    <item android:top="-2dp" android:bottom="2dp" android:left="2dp" android:right="2dp">
        <shape android:shape="rectangle">
            <corners android:bottomLeftRadius="9dp" android:bottomRightRadius="9dp" />
            <solid android:color="#203FBFF5" />
        </shape>
    </item>
    <item android:top="-2dp" android:bottom="3dp" android:left="3dp" android:right="3dp">
        <shape android:shape="rectangle">
            <corners android:bottomLeftRadius="8dp" android:bottomRightRadius="8dp" />
            <solid android:color="#303FBFF5" />
        </shape>
    </item>

    <!-- Main Gradient Body -->
    <item android:bottom="4dp" android:left="4dp" android:right="4dp" android:top="-2dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:endColor="#3FBFF5"
                android:startColor="#2F6BFF"
                android:type="linear" />
            <corners android:bottomLeftRadius="8dp" android:bottomRightRadius="8dp" />
        </shape>
    </item>
</layer-list>