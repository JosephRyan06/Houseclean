<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/card_border_green"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvDateTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MONDAY, 7:00 AM - 12:00 PM"
        android:textColor="#2DCC91"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#FBC02D"
        android:textSize="12sp"
        android:textStyle="bold|italic"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvDate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="January 1, 2026"
        android:textColor="#757575"
        android:textSize="12sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvDateTime" />

    <TextView
        android:id="@+id/labelService"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Service: "
        android:textColor="#000000"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvDate" />

    <TextView
        android:id="@+id/tvService"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Bathroom Cleaning"
        android:textColor="#000000"
        app:layout_constraintStart_toEndOf="@id/labelService"
        app:layout_constraintTop_toTopOf="@id/labelService" />

    <TextView
        android:id="@+id/labelHousekeeper"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Housekeeper: "
        android:textColor="#000000"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/labelService" />

    <TextView
        android:id="@+id/tvHousekeeper"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Afton, Michael"
        android:textColor="#000000"
        app:layout_constraintStart_toEndOf="@id/labelHousekeeper"
        app:layout_constraintTop_toTopOf="@id/labelHousekeeper" />

    <TextView
        android:id="@+id/labelPayment"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Payment: "
        android:textColor="#000000"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/labelHousekeeper" />

    <TextView
        android:id="@+id/tvPayment"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="PHP 500"
        android:textColor="#000000"
        app:layout_constraintStart_toEndOf="@id/labelPayment"
        app:layout_constraintTop_toTopOf="@id/labelPayment" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnViewDetails"
        style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:backgroundTint="#0B5036"
        android:text="VIEW DETAILS"
        android:textColor="#FFFFFF"
        android:textSize="10sp"
        app:cornerRadius="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvPayment" />

</androidx.constraintlayout.widget.ConstraintLayout>