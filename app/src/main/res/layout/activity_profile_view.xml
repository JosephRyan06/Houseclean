<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/profile_view_main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#333A5B"
    tools:context=".view.ProfileViewActivity">

    <!-- Header Section -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/profileHeader"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:background="#333A5B"
        app:layout_constraintTop_toTopOf="parent">

        <FrameLayout
            android:id="@+id/profileIconContainer"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_marginStart="24dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <View
                android:id="@+id/profileBg"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/profile_icon_bg" />

            <TextView
                android:id="@+id/tvProfileInitials"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="HK"
                android:textColor="#FFFFFF"
                android:textSize="32sp"
                android:textStyle="bold" />

            <View
                android:id="@+id/viewStatusStroke"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/profile_status_stroke" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="@id/profileIconContainer"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/profileIconContainer"
            app:layout_constraintTop_toTopOf="@id/profileIconContainer">

            <TextView
                android:id="@+id/tvProfileName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Last Name, First Name"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvProfileRole"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Housekeeper"
                android:textColor="#017497"
                android:textSize="14sp"
                android:textStyle="italic" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEditProfile"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/btn_gradient_blue"
                android:text="Edit Profile"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                app:backgroundTint="@null"
                app:cornerRadius="8dp" />
        </LinearLayout>

        <!-- Removed Theme Toggle ImageView -->

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- White Content Section -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="#FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/profileHeader"
        app:layout_constraintBottom_toTopOf="@id/bottomNavProfile">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:id="@+id/tvProfileRatings"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ratings: "
                    android:textColor="#757575"
                    android:textSize="14sp"
                    android:textStyle="italic|bold"
                    android:visibility="gone"
                    tools:visibility="visible"/>

                <TextView
                    android:id="@+id/tvProfileJoined"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Joined: "
                    android:textColor="#757575"
                    android:textSize="14sp"
                    android:textStyle="italic|bold" />

                <TextView
                    android:id="@+id/tvProfileEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Email: example@gmail.com"
                    android:textColor="#757575"
                    android:textSize="14sp"
                    android:textStyle="italic|bold" />

                <TextView
                    android:id="@+id/tvProfilePhone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Phone: "
                    android:textColor="#757575"
                    android:textSize="14sp"
                    android:textStyle="italic|bold" />

                <TextView
                    android:id="@+id/tvProfileAddress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Address: House Number / Street,\nBarangay, Landmark"
                    android:textColor="#757575"
                    android:textSize="14sp"
                    android:textStyle="italic|bold" />

                <TextView
                    android:id="@+id/tvProfileAvailability"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Availability: "
                    android:textColor="#757575"
                    android:textSize="14sp"
                    android:textStyle="italic|bold"
                    android:visibility="gone"
                    tools:visibility="visible"/>

                <TextView
                    android:id="@+id/tvProfileSkills"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Skills: "
                    android:textColor="#757575"
                    android:textSize="14sp"
                    android:textStyle="italic|bold"
                    android:visibility="gone"
                    tools:visibility="visible"/>

                <TextView
                    android:id="@+id/tvProfileExperience"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Experience: "
                    android:textColor="#757575"
                    android:textSize="14sp"
                    android:textStyle="italic|bold"
                    android:visibility="gone"
                    tools:visibility="visible"/>

                <TextView
                    android:id="@+id/tvSectionTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="REQUESTS"
                    android:textColor="#424242"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardStats"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:cardBackgroundColor="#D9D9D9"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvTotalRequests"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Total: 10"
                                android:textColor="#424242"
                                android:textSize="14sp"
                                android:textStyle="bold|italic" />

                            <TextView
                                android:id="@+id/tvConfirmedRequests"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:text="Confirmed: 2"
                                android:textColor="#424242"
                                android:textSize="14sp"
                                android:textStyle="bold|italic" />

                            <TextView
                                android:id="@+id/tvPendingRequests"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Pending: 3"
                                android:textColor="#424242"
                                android:textSize="14sp"
                                android:textStyle="bold|italic" />

                            <TextView
                                android:id="@+id/tvDeclinedRequests"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Declined: 5"
                                android:textColor="#424242"
                                android:textSize="14sp"
                                android:textStyle="bold|italic" />
                        </LinearLayout>

                        <ImageView
                            android:id="@+id/ivSectionIcon"
                            android:layout_width="80dp"
                            android:layout_height="80dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/request_image" />
                    </RelativeLayout>
                </androidx.cardview.widget.CardView>

                <TextView
                    android:id="@+id/tvPaymentSectionTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="PAYMENTS"
                    android:textColor="#424242"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    tools:visibility="visible"/>

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardPayments"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:cardBackgroundColor="#D9D9D9"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    android:visibility="gone"
                    tools:visibility="visible">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvTotalPayments"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Total: PHP 400"
                                android:textColor="#424242"
                                android:textSize="14sp"
                                android:textStyle="bold|italic" />

                            <TextView
                                android:id="@+id/tvPaidPayments"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:text="Paid: 2"
                                android:textColor="#424242"
                                android:textSize="14sp"
                                android:textStyle="bold|italic" />

                            <TextView
                                android:id="@+id/tvWaitingPayments"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Waiting: 0"
                                android:textColor="#424242"
                                android:textSize="14sp"
                                android:textStyle="bold|italic" />

                            <TextView
                                android:id="@+id/tvOverduePayments"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Overdue: 0"
                                android:textColor="#424242"
                                android:textSize="14sp"
                                android:textStyle="bold|italic" />
                        </LinearLayout>

                        <ImageView
                            android:layout_width="80dp"
                            android:layout_height="80dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/payment_image" />
                    </RelativeLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </ScrollView>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Bottom Log Out Section -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bottomNavProfile"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="#333A5B"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginHorizontal="24dp"
            android:background="@drawable/btn_gradient_red"
            android:text="Log Out"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="@null"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>