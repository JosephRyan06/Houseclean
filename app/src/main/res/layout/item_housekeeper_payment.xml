<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="16dp"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    app:contentPadding="16dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/tvPaymentHouseholderName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Last Name, First Name"
            android:textColor="#017497"
            android:textSize="18sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintEnd_toStartOf="@+id/profileIconContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/labelStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Status: "
            android:textColor="#424242"
            android:textSize="14sp"
            android:textStyle="italic"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvPaymentHouseholderName" />

        <TextView
            android:id="@+id/tvPaymentStatusValue"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Active"
            android:textColor="#2DCC91"
            android:textSize="14sp"
            android:textStyle="italic"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintBaseline_toBaselineOf="@id/labelStatus"
            app:layout_constraintEnd_toStartOf="@+id/profileIconContainer"
            app:layout_constraintStart_toEndOf="@id/labelStatus" />

        <TextView
            android:id="@+id/labelService"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Service: "
            android:textColor="#424242"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/labelStatus" />

        <TextView
            android:id="@+id/tvPaymentService"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Bathroom Cleaning"
            android:textColor="#424242"
            android:textSize="14sp"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintBaseline_toBaselineOf="@id/labelService"
            app:layout_constraintEnd_toStartOf="@+id/profileIconContainer"
            app:layout_constraintStart_toEndOf="@id/labelService" />

        <TextView
            android:id="@+id/labelSalary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Salary: "
            android:textColor="#424242"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/labelService" />

        <TextView
            android:id="@+id/tvPaymentSalary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="PHP 500"
            android:textColor="#424242"
            android:textSize="14sp"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintBaseline_toBaselineOf="@id/labelSalary"
            app:layout_constraintEnd_toStartOf="@+id/profileIconContainer"
            app:layout_constraintStart_toEndOf="@id/labelSalary" />

        <TextView
            android:id="@+id/labelSchedule"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Schedule: "
            android:textColor="#424242"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/labelSalary" />

        <TextView
            android:id="@+id/tvPaymentSchedule"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="March 16, 2026, 9:00 PM"
            android:textColor="#424242"
            android:textSize="14sp"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintBaseline_toBaselineOf="@id/labelSchedule"
            app:layout_constraintEnd_toStartOf="@+id/profileIconContainer"
            app:layout_constraintStart_toEndOf="@id/labelSchedule" />

        <FrameLayout
            android:id="@+id/profileIconContainer"
            android:layout_width="80dp"
            android:layout_height="80dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <View
                android:id="@+id/profileBg"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/profile_icon_bg" />

            <TextView
                android:id="@+id/tvProfileInitials"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="LF"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />

            <View
                android:id="@+id/viewStatusStroke"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/profile_status_stroke" />
        </FrameLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMarkPayment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/btn_gradient_blue"
            android:text="Mark Payment"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            app:backgroundTint="@null"
            app:cornerRadius="8dp"
            app:layout_constraintTop_toBottomOf="@id/tvPaymentSchedule" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>