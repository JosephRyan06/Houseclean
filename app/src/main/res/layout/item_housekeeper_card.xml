<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="280dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="12dp"
    android:background="@drawable/card_border_green"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvHKName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Afton, Micheal"
        android:textColor="#2DCC91"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@+id/ivHKProfile"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvHKService"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Bathroom Cleaning"
        android:textColor="#000000"
        android:textSize="12sp"
        android:textStyle="italic"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvHKName" />

    <TextView
        android:id="@+id/tvHKExperience"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="5 years Experience"
        android:textColor="#000000"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvHKService" />

    <TextView
        android:id="@+id/tvHKPhone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="09627182918"
        android:textColor="#000000"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvHKExperience" />

    <View
        android:id="@+id/ivHKProfile"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:background="#64FFDA"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnViewDetailsHK"
        style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:backgroundTint="#0B5036"
        android:text="VIEW DETAILS"
        android:textColor="#FFFFFF"
        android:textSize="10sp"
        app:cornerRadius="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvHKPhone" />

</androidx.constraintlayout.widget.ConstraintLayout>