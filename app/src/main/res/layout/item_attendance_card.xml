<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginEnd="16dp"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="#F5F5F5"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    app:contentPadding="16dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/tvHKName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Afton, Michael"
            android:textColor="#017497"
            android:textSize="18sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintEnd_toStartOf="@+id/profileIconContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvUserEmail"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="example@email.com"
            android:textColor="#5E6D82"
            android:textSize="12sp"
            android:textStyle="italic"
            android:visibility="visible"
            app:layout_constraintEnd_toStartOf="@+id/profileIconContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvHKName" />

        <TextView
            android:id="@+id/tvHKPhone"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="09123456789"
            android:textColor="#5E6D82"
            android:textSize="14sp"
            app:layout_constraintEnd_toStartOf="@+id/profileIconContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvUserEmail" />

        <RatingBar
            android:id="@+id/rbHKRating"
            style="?android:attr/ratingBarStyleSmall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:numStars="5"
            android:stepSize="0.1"
            android:progressTint="#FFD700"
            android:rating="4.5"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvHKPhone" />

        <TextView
            android:id="@+id/tvHKRatingsCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="(0 ratings)"
            android:textColor="#5E6D82"
            android:textSize="11sp"
            app:layout_constraintBottom_toBottomOf="@id/rbHKRating"
            app:layout_constraintStart_toEndOf="@id/rbHKRating"
            app:layout_constraintTop_toTopOf="@id/rbHKRating" />

        <TextView
            android:id="@+id/tvJoinedLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Joined: "
            android:textColor="#424242"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/rbHKRating" />

        <TextView
            android:id="@+id/tvJoinedValue"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="03/14/2006"
            android:textColor="#424242"
            android:textSize="14sp"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintBaseline_toBaselineOf="@id/tvJoinedLabel"
            app:layout_constraintEnd_toStartOf="@+id/profileIconContainer"
            app:layout_constraintStart_toEndOf="@id/tvJoinedLabel" />

        <TextView
            android:id="@+id/tvAvailableLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Available: "
            android:textColor="#424242"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvJoinedLabel" />

        <TextView
            android:id="@+id/tvAvailableValue"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Mon - Thur, 9:00 AM - 6:00 PM"
            android:textColor="#424242"
            android:textSize="14sp"
            android:maxLines="2"
            android:ellipsize="end"
            app:layout_constraintEnd_toStartOf="@+id/profileIconContainer"
            app:layout_constraintStart_toEndOf="@id/tvAvailableLabel"
            app:layout_constraintTop_toTopOf="@id/tvAvailableLabel" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnProfileDetails"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Check Profile"
            android:textAllCaps="false"
            android:textColor="#017497"
            android:textSize="14sp"
            app:strokeColor="#017497"
            app:cornerRadius="24dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvAvailableValue" />

        <TextView
            android:id="@+id/tvStatusLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Status: "
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btnProfileDetails" />

        <TextView
            android:id="@+id/tvStatusValue"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Active"
            android:visibility="gone"
            app:layout_constraintBaseline_toBaselineOf="@id/tvStatusLabel"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/tvStatusLabel" />

        <FrameLayout
            android:id="@+id/profileIconContainer"
            android:layout_width="64dp"
            android:layout_height="64dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <View
                android:id="@+id/profileBg"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/profile_icon_bg" />

            <TextView
                android:id="@+id/tvProfileInitials"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="AM"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />

            <View
                android:id="@+id/viewStatusStroke"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/profile_status_stroke" />
        </FrameLayout>

        <!-- Attendance Confirmation Message for Householder -->
        <TextView
            android:id="@+id/tvArrivalMessage"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="#FFE0E0"
            android:padding="8dp"
            android:text="Please confirm the staff has arrived at your location before payment or service begins."
            android:textColor="#E53935"
            android:textSize="13sp"
            android:textStyle="bold"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btnProfileDetails" />

        <!-- Buttons Section for Housekeeper -->
        <LinearLayout
            android:id="@+id/layoutHKButtons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/tvArrivalMessage">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMarkArrived"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/btn_gradient_blue"
                android:text="Mark Arrived"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:visibility="visible"
                app:backgroundTint="@null"
                app:cornerRadius="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnComplete"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/btn_gradient_blue"
                android:text="Complete"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:visibility="gone"
                app:backgroundTint="@null"
                app:cornerRadius="8dp" />
        </LinearLayout>

        <!-- Buttons Section for Householder -->
        <LinearLayout
            android:id="@+id/layoutHHButtons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/layoutHKButtons">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnYesArrived"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/btn_gradient_blue"
                android:text="Staff Arrived"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                app:backgroundTint="@null"
                app:cornerRadius="8dp" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>