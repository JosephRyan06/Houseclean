<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#FFFFFF">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvStep2Title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Start Service"
            android:textColor="#424242"
            android:textSize="28sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Progress Indicator -->
        <LinearLayout
            android:id="@+id/layoutProgress"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvStep2Title">
            <TextView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/register_step_active"
                android:gravity="center"
                android:text="1"
                android:textColor="#FFFFFF" />
            <View
                android:layout_width="60dp"
                android:layout_height="2dp"
                android:background="#017497" />
            <TextView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/register_step_active"
                android:gravity="center"
                android:text="2"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />
            <View
                android:layout_width="60dp"
                android:layout_height="2dp"
                android:background="#D9D9D9" />
            <TextView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/register_step_inactive"
                android:gravity="center"
                android:text="3"
                android:textColor="#424242" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutProgressLabels"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layoutProgress">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Service/Plan"
                android:textColor="#424242"
                android:textSize="12sp" />
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Schedule &amp; Worker"
                android:textColor="#017497"
                android:textSize="12sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Review"
                android:textColor="#424242"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Start Time Section -->
        <TextView
            android:id="@+id/tvWhenStartLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="WHEN WILL THEY START?"
            android:textColor="#002147"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layoutProgressLabels" />

        <TextView
            android:id="@+id/tvWhenStartDesc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Pick a date and time that works for you."
            android:textColor="#5E6D82"
            android:textSize="12sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvWhenStartLabel" />

        <LinearLayout
            android:id="@+id/layoutSchedulePicker"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvWhenStartDesc">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="DATE"
                    android:textColor="#5E6D82"
                    android:textSize="11sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:text="TIME"
                    android:textColor="#5E6D82"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">
                <EditText
                    android:id="@+id/etStartDate"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:focusable="false"
                    android:gravity="center_vertical"
                    android:hint="25/03/2026"
                    android:paddingHorizontal="4dp"
                    android:textColor="#002147"
                    android:textSize="16sp" />
                <EditText
                    android:id="@+id/etStartTime"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:background="@android:color/transparent"
                    android:focusable="false"
                    android:gravity="center_vertical"
                    android:hint="10:00 AM"
                    android:paddingHorizontal="4dp"
                    android:textColor="#002147"
                    android:textSize="16sp" />
            </LinearLayout>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:scrollbars="none">
                <LinearLayout
                    android:id="@+id/layoutTimeSlots"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <!-- Time slots will be added programmatically -->
                </LinearLayout>
            </HorizontalScrollView>
        </LinearLayout>

        <!-- Schedule Reminder Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardScheduleReminder"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#F0F4FF"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layoutSchedulePicker">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="12dp">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_alert"
                    app:tint="#017497" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Choose your schedule first"
                        android:textColor="#002147"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Select a date and time before searching for available staff."
                        android:textColor="#5E6D82"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Booking Type Section -->
        <LinearLayout
            android:id="@+id/layoutBookingButtons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/cardScheduleReminder">
            <TextView
                android:id="@+id/tvFindStaffLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Find Available Staff"
                android:textColor="#002147"
                android:textSize="16sp"
                android:textStyle="bold" />
            <Button
                android:id="@+id/btnQuickBook"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:background="@drawable/btn_gradient_blue"
                android:text="Quick Book"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                app:backgroundTint="@null" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvQuickBookDesc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Quick Book auto-assigns the least busy staff who match your schedule."
            android:textColor="#5E6D82"
            android:textSize="11sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layoutBookingButtons" />

        <!-- Staff Availability Stats Filters -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardFilterContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#F0F4FF"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvQuickBookDesc">
            <LinearLayout
                android:id="@+id/layoutStatsFilters"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="8dp">
                <TextView
                    android:id="@+id/tvFilterAvailable"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:background="@drawable/register_progress_line"
                    android:backgroundTint="#E6F9F1"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="8dp"
                    android:text="Available 0"
                    android:textColor="#2DCC91"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true"/>
                <TextView
                    android:id="@+id/tvFilterUnavailable"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:gravity="center"
                    android:background="@drawable/register_progress_line"
                    android:backgroundTint="#FFF6ED"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="8dp"
                    android:text="Unavailable 0"
                    android:textColor="#F48B29"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true"/>
                <TextView
                    android:id="@+id/tvFilterTotal"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:gravity="center"
                    android:background="@drawable/register_progress_line"
                    android:backgroundTint="#F8F9FA"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="8dp"
                    android:text="Total 0"
                    android:textColor="#5E6D82"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Staff List Section -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvHousekeepers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            app:layout_constraintTop_toBottomOf="@id/cardFilterContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:listitem="@layout/item_housekeeper_selectable" />

        <!-- Navigation Buttons -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layoutNavButtons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="24dp"
            app:layout_constraintTop_toBottomOf="@id/rvHousekeepers"
            app:layout_constraintBottom_toBottomOf="parent">

            <Button
                android:id="@+id/btnBackStep2"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Back"
                android:textAllCaps="false"
                android:textColor="#017497"
                app:strokeColor="#017497"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>

            <Button
                android:id="@+id/btnNextStep2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/btn_gradient_blue"
                android:text="Next"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                app:backgroundTint="@null"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
